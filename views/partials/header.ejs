<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Scholarship App</title>
    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background: #f4f6f8;
            color: #1f2937;
        }

        .site-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem 1.5rem;
            background: #0f172a;
            color: #fff;
            border-bottom: 4px solid #2563eb;
        }

        .site-header .brand a {
            color: #fff;
            text-decoration: none;
            font-size: 1.3rem;
            font-weight: 700;
        }

        .site-header nav {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .site-header nav a,
        .site-header nav .user-name {
            color: #f8fafc;
        }

        .site-header nav a.button {
            background: #2563eb;
            color: #fff;
            padding: 0.65rem 1rem;
            border-radius: 0.4rem;
            text-decoration: none;
        }

        .container,
        .form-page,
        .details-page {
            max-width: 960px;
            margin: 2rem auto;
            padding: 0 1.25rem;
        }

        .page-actions {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            margin-bottom: 1.25rem;
        }

        .card-grid {
            display: grid;
            gap: 1rem;
            grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        }

        .card {
            background: #fff;
            padding: 1.25rem;
            border-radius: 0.8rem;
            box-shadow: 0 8px 25px rgba(15, 23, 42, 0.08);
        }

        .card h2 {
            margin-top: 0;
        }

        .card a,
        .button.secondary,
        .button {
            display: inline-block;
            margin-top: 0.75rem;
            background: #2563eb;
            color: #fff;
            padding: 0.7rem 1rem;
            border-radius: 0.5rem;
            text-decoration: none;
        }

        .button.secondary {
            background: #64748b;
        }

        label {
            margin-top: 1rem;
            margin-bottom: 0.35rem;
            font-weight: 600;
        }

        input {
            width: 100%;
            padding: 0.85rem;
            border-radius: 0.5rem;
            border: 1px solid #cbd5e1;
            background: #fff;
            font-size: 1rem;
        }

        button[type='submit'] {
            margin-top: 1.25rem;
            cursor: pointer;
            background: #2563eb;
            color: #fff;
            padding: 0.85rem;
            border: none;
            border-radius: 0.6rem;
            font-size: 1rem;
        }

        .flash {
            max-width: 960px;
            margin: 1rem auto;
            padding: 1rem 1.25rem;
            border-radius: 0.75rem;
        }

        .flash.success {
            background: #dcfce7;
            color: #14532d;
        }

        .flash.error {
            background: #fee2e2;
            color: #991b1b;
        }

        .empty-state,
        .centered {
            text-align: center;
        }

        .site-footer {
            max-width: 960px;
            margin: 2rem auto;
            padding: 1rem 1.25rem;
            text-align: center;
            color: #475569;
        }
    </style>
</head>

<body>
    <header class="site-header">
        <div class="brand">
            <a href="/scholarship">Scholarship Portal</a>
        </div>
        <nav>
            <a href="/scholarship">Scholarships</a>
            <% if (currentUser) { %>
                <span class="user-name">Hello, <strong>
                        <%= currentUser.name %>
                    </strong></span>
                <a href="/logout" class="button">Logout</a>
                <% } else { %>
                    <a href="/login">Login</a>
                    <a href="/register">Register</a>
                    <% } %>
        </nav>
    </header>

    <% if (success && success.length) { %>
        <div class="flash success">
            <%= success %>
        </div>
        <% } %>
            <% if (error && error.length) { %>
                <div class="flash error">
                    <%= error %>
                </div>
                <% } %>